{
  "name": "@opentegrate/skill-greeting",
  "version": "1.0.0",
  "description": "A simple greeting skill for Opentegrate",
  "main": "dist/index.js",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./api": "./dist/api.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --bundle --outdir dist",
    "dev": "bun run --watch src/index.ts",
    "typecheck": "bun typecheck src",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opentegrate/core": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.1.34",
    "typescript": "^5.4.0"
  }
}