{
  "id": "skill-greeting",
  "name": "Greeting Skill",
  "version": "1.0.0",
  "description": "A simple greeting skill that can say hello and manage greetings",
  "targets": ["opentegrate"],
  "main": "dist/index.js",
  "capabilities": {
    "skills": [
      {
        "id": "greet",
        "name": "Greet User",
        "description": "Greet the user with a friendly message",
        "parameters": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Name to greet (defaults to 'World')"
            },
            "style": {
              "type": "string",
              "enum": ["formal", "casual", "enthusiastic"],
              "description": "Greeting style"
            }
          }
        },
        "examples": [
          {
            "input": { "name": "Alice", "style": "casual" },
            "output": "Hey Alice! Great to see you!"
          }
        ]
      },
      {
        "id": "greeting-history",
        "name": "Greeting History",
        "description": "Remember previous greetings and personalize responses",
        "parameters": {
          "type": "object",
          "properties": {
            "userId": {
              "type": "string",
              "description": "User identifier"
            }
          }
        }
      }
    ]
  },
  "dependencies": [],
  "permissions": ["conversation:read", "memory:write"],
  "configSchema": {
    "type": "object",
    "properties": {
      "defaultStyle": {
        "type": "string",
        "enum": ["formal", "casual", "enthusiastic"],
        "default": "casual"
      },
      "rememberUsers": {
        "type": "boolean",
        "default": true
      }
    }
  }
}